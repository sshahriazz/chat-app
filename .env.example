# ============================================================================
#  CHAT APP — .env.example  ── canonical reference for every env var
# ============================================================================
# This is the ONLY env file the project uses. Copy it to `.env` at the repo
# root and `make dev` will just work. The server reads from this same file
# whether it runs via `pnpm dev` (dotenv loads ../../.env) or via docker
# (compose injects it as process.env). There is no `apps/server/.env` —
# that path was removed; the root file is the single source of truth.
#
# Layering:
#   - Local dev  → root `.env` is loaded by `make dev` and by the server's
#                  dotenv. compose.dev.yml adds host-port bindings.
#   - Production → Dokploy's env panel REPLACES this file. docker-compose.yml
#                  is the only compose file Dokploy reads; every secret
#                  there is `${VAR:?required}` so a missing env aborts the
#                  deploy loudly.
#
# Every value below is a WORKING DEV DEFAULT.
#
# ⚠️  DO NOT USE THESE SECRETS IN PRODUCTION. Every key is committed to git
#     and publicly readable. For Dokploy, set every value in the ━━━ PROD ━━━
#     sections below to a freshly-rotated one. Generation commands:
#
#        openssl rand -hex 32                      # CENTRIFUGO_*_SECRET, *_API_KEY, MASTER_API_KEY
#        openssl rand -base64 32                   # JWT_SECRET_ENCRYPTION_KEY (must be 32 bytes)
#        openssl rand -base64 24                   # POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD
#        npx web-push generate-vapid-keys          # VAPID_* trio
#
#     The server REFUSES TO BOOT in production if it sees the dev defaults
#     for CENTRIFUGO_TOKEN_SECRET / CENTRIFUGO_API_KEY / S3_SECRET_ACCESS_KEY,
#     or the dev `chatapp:chatapp` DB credentials.
# ============================================================================


# ─── PUBLIC URLS ───────────────────────────────────────────────
# Where the browser reaches each backend. In production these are all
# the SAME origin (Traefik routes `/api`, `/connection/websocket`,
# `/chatapp` to the right container). Locally there's no Traefik, so
# each service is reached on its own host-bound port — the values here
# match what `compose.dev.yml` binds (server :3001, centrifugo :8000,
# minio :9000).
#
# For deployment: swap the per-port localhost URLs for your real
# domain. Example values for `https://chat.technext.it`:
#     PUBLIC_URL=https://chat.technext.it
#     CORS_ALLOWED_ORIGINS=https://chat.technext.it
#     S3_PUBLIC_URL_BASE=https://chat.technext.it/chatapp
#     OPENAPI_SERVER_URL=  # empty → falls back to ${PUBLIC_URL}/api
#
# `compose.dev.yml` already overrides S3_PUBLIC_URL_BASE and
# OPENAPI_SERVER_URL for local dev so stale values here can't break it.
PUBLIC_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
S3_PUBLIC_URL_BASE=http://localhost:9000/chatapp
OPENAPI_SERVER_URL=http://localhost:3001/api


# ─── REALTIME SECRETS  ━━━ Generate fresh for EVERY environment ━━━
# Run for each one:  openssl rand -hex 32
# Never commit a real secret; CI / pre-commit hooks scan for it.
CENTRIFUGO_TOKEN_SECRET=__REPLACE_WITH__openssl_rand_hex_32__
CENTRIFUGO_API_KEY=__REPLACE_WITH__openssl_rand_hex_32__

# Centrifugo admin UI: SHIPPED DISABLED in centrifugo.json. Leave these
# blank unless you've also flipped `admin.enabled: true` and locked the
# admin port behind an internal network / Traefik basic auth. If you
# do enable it, generate both via:  openssl rand -hex 32
CENTRIFUGO_ADMIN_PASSWORD=
CENTRIFUGO_ADMIN_SECRET=


# ─── TENANCY  ━━━ PROD: set MASTER_API_KEY + lock admin endpoints ━━━
# Gate for `/api/admin/*` (create tenants, rotate keys).
# Leave empty in dev → admin endpoints return 403.
MASTER_API_KEY=

# Optional comma-separated IP allowlist for `/api/admin/*` sources.
# A leaked MASTER_API_KEY alone isn't enough if set. Leave empty → any IP.
# Example: ADMIN_IP_ALLOWLIST=203.0.113.4,198.51.100.7
ADMIN_IP_ALLOWLIST=

# Optional base64-encoded 32-byte key. When set, Tenant.jwtSecret is
# AES-256-GCM wrapped at rest. Legacy plaintext rows stay readable.
# Generate with: openssl rand -base64 32
JWT_SECRET_ENCRYPTION_KEY=

# When "true", every `POST /api/webhooks/*` must carry a valid
# `X-Chat-Signature` header. DEFAULTS ON — a leaked tenant API key
# alone is otherwise enough to forge webhook payloads. Set to `false`
# only as a short-lived migration window while tenants ship the signer.
WEBHOOK_SIGNATURE_REQUIRED=true

# Seconds of clock skew tolerated when verifying tenant-signed user JWTs.
TENANT_JWT_CLOCK_SKEW_SEC=30

# Auth mode. Post-better-auth cutover the server only accepts JWT —
# `session`/`both` exist in the enum as rollback escape hatches.
AUTH_MODE=jwt

# Dev-only: mounts `POST /api/dev/mint-token` so the reference client's
# demo sign-in works. PROD MUST SET BOTH TO FALSE / EMPTY.
DEV_MINT_ENABLED=false
ALLOW_DEV_MINT_TENANTS=


# ─── INFRA  ━━━ PROD: rotate credentials ━━━
# Postgres. `chatapp:chatapp` is the dev default and is rejected by the
# server's prod startup guard.
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=chatapp
POSTGRES_DB=chatapp

# MinIO. `chatapp-dev-only` is also rejected by the prod guard.
MINIO_ROOT_USER=chatapp
MINIO_ROOT_PASSWORD=chatapp-dev-only
MINIO_BUCKET=chatapp

# Redis password — mandatory in prod (`requirepass`). Generate via:
#     openssl rand -base64 24
# Local dev: pick any value; just must be set so the redis container
# boots and every consumer URL embeds the same value.
REDIS_PASSWORD=chatapp-dev-only

# Two proxy hops: Traefik → web (Next) → server. Sets Express's trust-proxy
# so req.ip reflects the real client (needed for admin IP allowlist +
# rate limiters).
TRUST_PROXY=2


# ─── WEB PUSH ──────────────────────────────────────────────────
# Generate a fresh VAPID keypair per environment:
#     npx web-push generate-vapid-keys
# The private key is signing material — treat it as a secret. A leaked
# private key lets an attacker spoof push notifications to any user
# subscribed against the matching public key.
VAPID_PUBLIC_KEY=__REPLACE_WITH__web-push_generate-vapid-keys_public__
VAPID_PRIVATE_KEY=__REPLACE_WITH__web-push_generate-vapid-keys_private__
VAPID_SUBJECT=mailto:admin@example.com


# ─── WEB BUNDLE (browser-facing, baked at `next build` time) ───
# Production: leave BLANK. The browser uses same-origin relative paths
# (`/api/…`, `/connection/websocket`, `/chatapp/…`) and Traefik on the
# Dokploy host routes each path to the right backend container. No
# CORS, one TLS cert, one domain.
#
# Local dev: `compose.dev.yml` overrides both build args to point at
# the host-bound backend ports — you do NOT need to set them here.
#     NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
#     NEXT_PUBLIC_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket
#
# Set values here only for custom deployments (e.g. dedicated api/ws
# subdomains with their own Traefik routes).
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_CENTRIFUGO_URL=


# ─── INTERNAL (don't change) ───────────────────────────────────
# Server reaches MinIO over the compose network for HEAD/DELETE.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1


# ─── HOST PORT (only honored outside Dokploy/Traefik) ──────────
# Dokploy's Traefik routes a domain directly to the web container via
# the compose network and ignores this binding. It only matters when you
# `docker compose up` on bare metal.
WEB_PORT=3000
