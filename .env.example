# ============================================================================
#  CHAT APP — .env.example
# ============================================================================
# Every value below is a WORKING DEV DEFAULT. Copy this file to `.env` and
# `docker compose up -d` will just work.
#
# ⚠️  DO NOT USE THESE SECRETS IN PRODUCTION. Every key is committed to git
#     and publicly readable. For Dokploy, set every value in the ━━━ PROD ━━━
#     sections below to a freshly-rotated one. Generation commands:
#
#        openssl rand -hex 32                      # CENTRIFUGO_*_SECRET, *_API_KEY, MASTER_API_KEY
#        openssl rand -base64 32                   # JWT_SECRET_ENCRYPTION_KEY (must be 32 bytes)
#        openssl rand -base64 24                   # POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD
#        npx web-push generate-vapid-keys          # VAPID_* trio
#
#     The server REFUSES TO BOOT in production if it sees the dev defaults
#     for CENTRIFUGO_TOKEN_SECRET / CENTRIFUGO_API_KEY / S3_SECRET_ACCESS_KEY,
#     or the dev `chatapp:chatapp` DB credentials.
# ============================================================================


# ─── PUBLIC URLS ───────────────────────────────────────────────
# Everything the browser touches lives on one origin — the web container.
# Swap `http://localhost:3000` for your real domain (e.g.
# `https://chat.technext.it`) when deploying.
PUBLIC_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
S3_PUBLIC_URL_BASE=http://localhost:3000/chatapp


# ─── REALTIME SECRETS  ━━━ PROD: rotate with `openssl rand -hex 32` ━━━
CENTRIFUGO_TOKEN_SECRET=ff3ee27fc22c690c973e6d4d267e515355eae5a7f93a8795cf8780d47f40c63b
CENTRIFUGO_API_KEY=05937eec99ae20a3d5f17c0f7f2e61fa23c76ee1f8a1bfc984795eba43e3fa09

# Centrifugo admin UI — disable admin in centrifugo.json if you don't need
# it, otherwise rotate these two before exposing the service.
CENTRIFUGO_ADMIN_PASSWORD=admin
CENTRIFUGO_ADMIN_SECRET=e88809d7d02926ac87ddc156bcd39e2939794513469a0a93f26b14dfe5315667


# ─── TENANCY  ━━━ PROD: set MASTER_API_KEY + lock admin endpoints ━━━
# Gate for `/api/admin/*` (create tenants, rotate keys).
# Leave empty in dev → admin endpoints return 403.
MASTER_API_KEY=

# Optional comma-separated IP allowlist for `/api/admin/*` sources.
# A leaked MASTER_API_KEY alone isn't enough if set. Leave empty → any IP.
# Example: ADMIN_IP_ALLOWLIST=203.0.113.4,198.51.100.7
ADMIN_IP_ALLOWLIST=

# Optional base64-encoded 32-byte key. When set, Tenant.jwtSecret is
# AES-256-GCM wrapped at rest. Legacy plaintext rows stay readable.
# Generate with: openssl rand -base64 32
JWT_SECRET_ENCRYPTION_KEY=

# When "true", every `POST /api/webhooks/*` must carry a valid
# `X-Chat-Signature` header. Off by default for easy onboarding;
# flip on once your tenants have shipped the HMAC signer.
WEBHOOK_SIGNATURE_REQUIRED=false

# Seconds of clock skew tolerated when verifying tenant-signed user JWTs.
TENANT_JWT_CLOCK_SKEW_SEC=30

# Auth mode. Post-better-auth cutover the server only accepts JWT —
# `session`/`both` exist in the enum as rollback escape hatches.
AUTH_MODE=jwt

# Dev-only: mounts `POST /api/dev/mint-token` so the reference client's
# demo sign-in works. PROD MUST SET BOTH TO FALSE / EMPTY.
DEV_MINT_ENABLED=false
ALLOW_DEV_MINT_TENANTS=


# ─── INFRA  ━━━ PROD: rotate credentials ━━━
# Postgres. `chatapp:chatapp` is the dev default and is rejected by the
# server's prod startup guard.
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=chatapp
POSTGRES_DB=chatapp

# MinIO. `chatapp-dev-only` is also rejected by the prod guard.
MINIO_ROOT_USER=chatapp
MINIO_ROOT_PASSWORD=chatapp-dev-only
MINIO_BUCKET=chatapp

# Two proxy hops: Traefik → web (Next) → server. Sets Express's trust-proxy
# so req.ip reflects the real client (needed for admin IP allowlist +
# rate limiters).
TRUST_PROXY=2


# ─── WEB PUSH (freshly-generated VAPID — safe to use in dev) ───
# These were generated with `npx web-push generate-vapid-keys` specifically
# for this example file. Generate your own for any real deployment.
VAPID_PUBLIC_KEY=BNg5G8BbJHF7Kd_t09Z-NFV-jwLWIu6Fhb3OkHC668JHlvozIxL-nJDBwPG0TmMITam0u3RP0LQzN0Q5mRS9SzI
VAPID_PRIVATE_KEY=EOgeESmll3VqwHOJ0buIFTwSMlLGhFkcTmXB9H9V9D4
VAPID_SUBJECT=mailto:admin@example.com


# ─── BUILD-TIME (Next.js rewrite targets) ──────────────────────
# These are internal compose-network URLs. Keep as-is unless you rename
# services in docker-compose.yml. They're baked into .next/routes-manifest
# at build time, so changes require a rebuild (Dokploy's "Deploy" does
# this automatically on tag/push).
API_PROXY_URL=http://server:3001
WS_PROXY_URL=http://centrifugo:8000
STORAGE_PROXY_URL=http://minio:9000

# Leave BLANK — same-origin via Next rewrites is what we want. Only set
# if you're running the API or WS on a separate public subdomain.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_CENTRIFUGO_URL=


# ─── INTERNAL (don't change) ───────────────────────────────────
# Server reaches MinIO over the compose network for HEAD/DELETE.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1


# ─── HOST PORT (only honored outside Dokploy/Traefik) ──────────
# Dokploy's Traefik routes a domain directly to the web container via
# the compose network and ignores this binding. It only matters when you
# `docker compose up` on bare metal.
WEB_PORT=3000
