# ============================================================================
#  CHAT APP — production environment
# ============================================================================
# Paste this into Dokploy's "Environment Variables" panel, replacing every
# "CHANGE_ME…" value and the example domain (`chat.example.com`) with yours.
#
# Generate strong secrets with:     openssl rand -hex 32
# Generate VAPID keys with:         npx web-push generate-vapid-keys
#
# Dokploy's compose deploy reads BOTH runtime env and build-args from this
# single file — just paste.
# ============================================================================


# ─── PUBLIC URLS (update domain) ───────────────────────────────
# The web container is the only service bound to a public port. /api,
# /connection/websocket, and /chatapp are served from the SAME domain
# via Next.js rewrites — no subdomains needed.
BETTER_AUTH_URL=https://chat.example.com
CORS_ALLOWED_ORIGINS=https://chat.example.com

# Browsers fetch attachments from this URL. Must include the bucket name.
S3_PUBLIC_URL_BASE=https://chat.example.com/chatapp


# ─── SECRETS (rotate regularly) ────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME_openssl_rand_hex_32_at_least_32_chars
CENTRIFUGO_TOKEN_SECRET=CHANGE_ME_openssl_rand_hex_32
CENTRIFUGO_API_KEY=CHANGE_ME_openssl_rand_hex_32

# Centrifugo admin UI creds (disable admin UI in centrifugo.json if you
# don't need it; otherwise these protect it).
CENTRIFUGO_ADMIN_PASSWORD=CHANGE_ME_strong_password
CENTRIFUGO_ADMIN_SECRET=CHANGE_ME_openssl_rand_hex_32

# Postgres
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=chatapp

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=chatapp
# Must be ≥ 8 chars.
MINIO_ROOT_PASSWORD=CHANGE_ME_min_8_chars
MINIO_BUCKET=chatapp


# ─── WEB PUSH (optional — leave blank to disable) ──────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com


# ─── BUILD-TIME (Next.js rewrite targets) ──────────────────────
# Baked into .next/routes-manifest at build. Defaults use compose DNS
# names — leave these alone unless you rename services.
API_PROXY_URL=http://server:3001
WS_PROXY_URL=http://centrifugo:8000
STORAGE_PROXY_URL=http://minio:9000

# Client bundle env. Leave BLANK — same-origin via Next rewrites is
# cleanest. Override only if API or WS run on separate public subdomains.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_CENTRIFUGO_URL=


# ─── INTERNAL (don't change on Dokploy) ────────────────────────
# The server reaches MinIO directly via the compose network for HEAD/DELETE.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1


# ─── HOST PORT (only relevant outside Dokploy) ─────────────────
# Dokploy/Traefik routes a domain directly to the web container over the
# compose network and ignores this host binding. It only matters when
# running `docker compose up` on bare metal.
WEB_PORT=3000
