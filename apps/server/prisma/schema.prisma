generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Auto-derived Zod schemas for every model + enum. Used as the source of
// truth for input validation + OpenAPI request/response schemas. Picking
// `pure` variants (no Prisma-client type helpers) keeps them usable from
// any consumer — server routes, client bundles, migrations.
generator zod {
  provider         = "prisma-zod-generator"
  output           = "../src/generated/zod"
  useMultipleFiles = true
  createInputTypes = false
  createModelTypes = true
}

datasource db {
  provider = "postgresql"
}

// ─── Tenancy ──────────────────────────────────────────────────
//
// A Tenant is a third-party app that uses this chat server. Every chat
// entity (User, Conversation, Message, …) is scoped to exactly one
// tenant, enforced at the query layer so two tenants can't see each
// other's data even with a bug in route authorization.
//
// `apiKeyHash` is Argon2(apiKey) — the raw key is surfaced exactly
// once at create/rotate time. Tenants authenticate server-to-server
// endpoints by sending `Authorization: Bearer <apiKey>`.
//
// `jwtSecret` is the HMAC secret the tenant uses to sign user JWTs
// for their end-users. Their backend mints a short-lived token with
// `sub = externalId` + name/image/email claims; we verify with this
// secret and upsert a User row keyed by `(tenantId, externalId)`.
//
// A single `default` tenant is seeded by the initial tenancy
// migration and carries every pre-existing row.

model Tenant {
  id         String   @id @default(uuid())
  name       String
  apiKeyHash String   @map("api_key_hash")
  jwtSecret  String   @map("jwt_secret")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  users               User[]
  conversations       Conversation[]
  conversationMembers ConversationMember[]
  messages            Message[]
  reactions           Reaction[]
  attachments         Attachment[]
  pushSubscriptions   PushSubscription[]

  @@map("tenant")
}

// ─── User (tenant-federated) ───────────────────────────────────
//
// Post-cutover: the better-auth tables (Session, Account, Verification)
// are gone; identity is carried by tenant-signed JWTs and materialized
// here lazily on first authenticated request. `email` is display-only
// now — no longer unique, nullable.

model User {
  id           String    @id
  // Tenant-scoped composite identity. `externalId` is the tenant's own
  // user id (never mutated), `id` stays server-internal (UUID) so our
  // FKs / Centrifugo channels don't need to change.
  tenantId     String    @default("default") @map("tenant_id")
  externalId   String    @map("external_id")
  name         String
  email        String?
  image        String?
  lastActiveAt DateTime? @map("last_active_at")
  createdAt    DateTime  @map("created_at")
  updatedAt    DateTime  @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationMembers ConversationMember[]
  messages            Message[]
  reactions           Reaction[]
  attachments         Attachment[]
  pushSubscriptions   PushSubscription[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@map("user")
}

// ─── Chat tables ──────────────────────────────────────────────

enum ConversationType {
  direct
  group
}

enum MemberRole {
  owner
  admin
  member
}

enum MessageType {
  text
  system
  image
}

model Conversation {
  id         String           @id @default(uuid())
  tenantId   String           @default("default") @map("tenant_id")
  type       ConversationType
  name       String?
  createdBy  String           @map("created_by")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  // Bumped on any membership/meta change so clients can reject stale events.
  version    Int              @default(0)
  // Per-conversation monotonic counter; incremented atomically when a message
  // is inserted to produce `Message.seq`.
  currentSeq Int              @default(0) @map("current_seq")

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members  ConversationMember[]
  messages Message[]

  @@index([tenantId])
  @@map("conversations")
}

model ConversationMember {
  id                String     @id @default(uuid())
  tenantId          String     @default("default") @map("tenant_id")
  conversationId    String     @map("conversation_id")
  userId            String     @map("user_id")
  role              MemberRole @default(member)
  joinedAt          DateTime   @default(now()) @map("joined_at")
  lastReadMessageId String?    @map("last_read_message_id")
  lastReadAt        DateTime?  @map("last_read_at")
  muted             Boolean    @default(false)
  // Denormalized running count of unread messages from others. Incremented
  // in the message-send transaction for every non-sender member; zeroed when
  // the member marks the conversation read. Avoids an N+1 count query on
  // every /init + /conversations request.
  unreadCount       Int        @default(0) @map("unread_count")

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage Message?     @relation("LastReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([conversationId, userId])
  @@index([tenantId])
  @@map("conversation_members")
}

/// Outbox for Centrifugo's native PostgreSQL consumer.
///
/// Rows are inserted inside the same transaction as the business write
/// (message create, edit, reaction, etc). Centrifugo polls this table,
/// executes the indicated `method` (e.g. "broadcast") with the payload,
/// and deletes the row. Guarantees at-least-once event delivery that
/// survives both app-server crashes and Centrifugo downtime without
/// losing the atomic property of the underlying write.
model Outbox {
  id        BigInt   @id @default(autoincrement())
  method    String   @default("broadcast")
  payload   Json
  partition BigInt   @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([partition, id])
  @@map("chat_outbox")
}

model PushSubscription {
  id        String   @id @default(uuid())
  tenantId  String   @default("default") @map("tenant_id")
  userId    String   @map("user_id")
  // Unique per browser: the endpoint is the browser's Push service URL plus
  // a client-specific path. Upserting on it avoids duplicates when the same
  // browser re-subscribes.
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("push_subscriptions")
}

model Attachment {
  id          String   @id @default(uuid())
  tenantId    String   @default("default") @map("tenant_id")
  // Nullable so the upload flow can mint the row before the user hits "send".
  // Orphan attachments (messageId remains null past some TTL) can be GC'd.
  messageId   String?  @map("message_id")
  uploaderId  String   @map("uploader_id")
  url         String
  contentType String   @map("content_type")
  filename    String
  size        Int
  width       Int?
  height      Int?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([uploaderId, createdAt])
  @@index([tenantId])
  @@map("attachments")
}

model Message {
  id              String      @id @default(uuid())
  tenantId        String      @default("default") @map("tenant_id")
  conversationId  String      @map("conversation_id")
  senderId        String      @map("sender_id")
  // Tiptap AST — stored as jsonb so we never ship HTML over the wire or
  // trust client-supplied HTML. Canonicalized server-side at write time.
  content         Json
  // Flattened text for trigram search + sidebar previews. Maintained
  // alongside `content` in the same transaction; GIN trgm index lives on
  // this column (`messages_plain_content_trgm_idx`).
  plainContent    String      @default("") @map("plain_content")
  type            MessageType @default(text)
  replyToId       String?     @map("reply_to_id")
  editedAt        DateTime?   @map("edited_at")
  deletedAt       DateTime?   @map("deleted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  // Per-conversation monotonic sequence. Generated atomically on insert by
  // incrementing `Conversation.currentSeq` inside the message-create
  // transaction. Used for ordering + gap detection on the client.
  seq             Int
  // Optional dedup key provided by clients for optimistic UI + retries.
  clientMessageId String?     @map("client_message_id")

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?             @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]            @relation("MessageReplies")
  readBy       ConversationMember[] @relation("LastReadMessage")
  reactions    Reaction[]
  attachments  Attachment[]

  @@unique([conversationId, seq])
  @@unique([conversationId, clientMessageId])
  @@index([conversationId, createdAt])
  @@index([tenantId])
  @@map("messages")
}

model Reaction {
  id        String   @id @default(uuid())
  tenantId  String   @default("default") @map("tenant_id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([tenantId])
  @@map("reactions")
}
