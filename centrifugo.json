{
  "client": {
    "token": {
      "hmac_secret_key": "dev-secret-change-in-production"
    },
    "allowed_origins": ["http://localhost:3000", "http://192.168.0.101:3000"]
  },
  "http_api": {
    "key": "dev-api-key"
  },
  "admin": {
    "enabled": true,
    "password": "admin",
    "secret": "dev-admin-secret"
  },
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis://redis:6379/0"
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "user",
        "history_size": 300,
        "history_ttl": "600s",
        "force_recovery": true
      },
      {
        "name": "presence",
        "presence": true,
        "join_leave": true,
        "force_push_join_leave": true,
        "allow_presence_for_subscriber": true
      }
    ]
  },
  "consumers": [
    {
      "name": "postgresql",
      "type": "postgresql",
      "postgresql": {
        "dsn": "postgres://chatapp:chatapp@postgres:5432/chatapp",
        "outbox_table_name": "chat_outbox",
        "num_partitions": 1,
        "partition_select_limit": 100,
        "partition_poll_interval": "300ms",
        "partition_notification_channel": "centrifugo_partition_change"
      },
      "enabled": true
    }
  ]
}
