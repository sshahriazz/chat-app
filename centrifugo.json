{
  "client": {
    "allowed_origins": ["http://localhost:3000"]
  },
  "admin": {
    "enabled": false
  },
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis://redis:6379/0"
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "user",
        "history_size": 300,
        "history_ttl": "600s",
        "force_recovery": true,
        "allow_subscribe_for_client": false,
        "allow_subscribe_for_anonymous": false
      },
      {
        "name": "presence",
        "presence": true,
        "join_leave": true,
        "force_push_join_leave": true,
        "allow_presence_for_subscriber": true,
        "allow_subscribe_for_anonymous": false
      }
    ]
  }
}
