# Applies to builds that use the repo root as context.
# Keeps pnpm-workspace.yaml / lockfile IN so the workspace resolves
# correctly inside the container.

node_modules
**/node_modules
**/dist
**/.next
**/.turbo
**/coverage

# Local env files — every compose target is expected to inject env
# vars explicitly; never bake `.env` into an image.
.env
.env.*
!.env.example
**/.env
**/.env.*

# VCS + editor
.git
.gitignore
.github
.vscode
.idea
*.swp

# Backups + dumps that shouldn't ship
backups
*.dump

# Log output
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

.DS_Store
